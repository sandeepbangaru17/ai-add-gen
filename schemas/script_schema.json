{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["total_duration_seconds", "scenes"],
  "properties": {
    "total_duration_seconds": {
      "type": "integer",
      "description": "Total duration of all scenes combined"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "duration_seconds", "voiceover", "on_screen_text", "visual_description"],
        "properties": {
          "scene_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Unique scene identifier"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 1,
            "description": "Duration of the scene in seconds"
          },
          "voiceover": {
            "type": "string",
            "maxLength": 100,
            "description": "Narration text (keep under 20 words)"
          },
          "on_screen_text": {
            "type": "string",
            "description": "Text displayed on screen during the scene"
          },
          "visual_description": {
            "type": "string",
            "description": "Description of visuals for AI image generation"
          }
        }
      }
    }
  }
}
