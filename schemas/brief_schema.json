{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["product_name", "target_audience", "ad_duration_seconds", "tone", "platform", "cta"],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the product or service being advertised"
    },
    "tagline": {
      "type": "string",
      "description": "Optional tagline or slogan"
    },
    "target_audience": {
      "type": "string",
      "description": "Description of the target audience"
    },
    "ad_duration_seconds": {
      "type": "integer",
      "enum": [15, 30, 60],
      "description": "Duration of the ad in seconds (must be 15, 30, or 60)"
    },
    "tone": {
      "type": "string",
      "description": "Tone of the ad (e.g., 'professional, energetic')"
    },
    "platform": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "List of target platforms"
    },
    "cta": {
      "type": "string",
      "maxLength": 60,
      "description": "Call to action text (max 60 characters)"
    },
    "brand_colors": {
      "type": "array",
      "items": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
      "description": "List of hex color codes"
    },
    "logo_url": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL to brand logo"
    }
  }
}
